{
  "title": "Node Exporter Full",
  "uid": "node-exporter-full",
  "tags": ["node-eye", "node"],
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "editable": true,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "host",
        "type": "query",
        "query": "label_values(node_boot_time_seconds, instance)",
        "refresh": 1,
        "sort": 0
      }
    ]
  },
  "panels": [
    {
      "title": "CPU Usage",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      },
      "targets": [{
        "expr": "1 - avg(rate(node_cpu_seconds_total{mode=\"idle\", instance=~\"$host\"}[5m]))",
        "legendFormat": "CPU"
      }]
    },
    {
      "title": "Load Average",
      "type": "stat",
      "gridPos": { "h": 6, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 4 }
            ]
          }
        }
      },
      "targets": [{
        "expr": "node_load1{instance=~\"$host\"}",
        "legendFormat": "1m"
      },{
        "expr": "node_load5{instance=~\"$host\"}",
        "legendFormat": "5m"
      },{
        "expr": "node_load15{instance=~\"$host\"}",
        "legendFormat": "15m"
      }]
    },
    {
      "title": "Uptime",
      "type": "stat",
      "gridPos": { "h": 6, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "dtdurations",
          "decimals": 1
        }
      },
      "targets": [{
        "expr": "time() - node_boot_time_seconds{instance=~\"$host\"}",
        "legendFormat": "uptime"
      }]
    },
    {
      "title": "CPU Usage (by core)",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "targets": [{
        "expr": "1 - rate(node_cpu_seconds_total{mode=\"idle\", instance=~\"$host\"}[5m])",
        "legendFormat": "total"
      }]
    },
    {
      "title": "RAM Usage",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0 },
              { "color": "red", "value": 0 }
            ]
          }
        }
      },
      "targets": [{
        "expr": "node_memory_MemTotal_bytes{instance=~\"$host\"} - node_memory_MemAvailable_bytes{instance=~\"$host\"}",
        "legendFormat": "used"
      },{
        "expr": "node_memory_MemTotal_bytes{instance=~\"$host\"}",
        "legendFormat": "total"
      }]
    },
    {
      "title": "RAM Breakdown",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      },
      "targets": [{
        "expr": "node_memory_MemTotal_bytes{instance=~\"$host\"}",
        "legendFormat": "Total"
      },{
        "expr": "node_memory_MemAvailable_bytes{instance=~\"$host\"}",
        "legendFormat": "Available"
      },{
        "expr": "node_memory_MemFree_bytes{instance=~\"$host\"}",
        "legendFormat": "Free"
      },{
        "expr": "node_memory_Buffers_bytes{instance=~\"$host\"}",
        "legendFormat": "Buffers"
      },{
        "expr": "node_memory_Cached_bytes{instance=~\"$host\"}",
        "legendFormat": "Cached"
      }]
    },
    {
      "title": "Disk Space",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "displayMode": "color-background",
            "minWidth": 100
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0 },
              { "color": "red", "value": 0 }
            ]
          }
        }
      },
      "targets": [{
        "expr": "100 - (node_filesystem_avail_bytes{mountpoint=\"/\", instance=~\"$host\"} / node_filesystem_size_bytes{mountpoint=\"/\", instance=~\"$host\"} * 100)",
        "legendFormat": "Usage %"
      },{
        "expr": "node_filesystem_size_bytes{mountpoint=\"/\", instance=~\"$host\"}",
        "legendFormat": "Size"
      }]
    },
    {
      "title": "Disk IO",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "iops"
        }
      },
      "targets": [{
        "expr": "rate(node_disk_reads_completed_total{instance=~\"$host\", device=~\"sd.*|nvme.*|vd.*\"}[5m])",
        "legendFormat": "reads {{device}}"
      },{
        "expr": "rate(node_disk_writes_completed_total{instance=~\"$host\", device=~\"sd.*|nvme.*|vd.*\"}[5m])",
        "legendFormat": "writes {{device}}"
      }]
    },
    {
      "title": "Network Traffic",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 18, "x": 0, "y": 21 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bps"
        }
      },
      "targets": [{
        "expr": "rate(node_network_receive_bytes_total{instance=~\"$host\", device!=\"lo\"}[5m]) * 8",
        "legendFormat": "in {{device}}"
      },{
        "expr": "rate(node_network_transmit_bytes_total{instance=~\"$host\", device!=\"lo\"}[5m]) * 8",
        "legendFormat": "out {{device}}"
      }]
    },
    {
      "title": "Network Errors",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 21 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "cps"
        }
      },
      "targets": [{
        "expr": "rate(node_network_receive_drop_total{instance=~\"$host\", device!=\"lo\"}[5m])",
        "legendFormat": "drop {{device}}"
      },{
        "expr": "rate(node_network_receive_errors_total{instance=~\"$host\", device!=\"lo\"}[5m])",
        "legendFormat": "error {{device}}"
      }]
    }
  ]
}
