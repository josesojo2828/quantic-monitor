{
  "title": "SSH Security Monitor",
  "uid": "ssh-security",
  "tags": ["node-eye", "security", "ssh"],
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "editable": true,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h"]
  },
  "panels": [
    {
      "title": "Failed Logins (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      },
      "targets": [{
        "expr": "sum(increase(auth_ssh_failed_total[24h]))",
        "legendFormat": "Failed"
      }]
    },
    {
      "title": "Successful Logins (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      },
      "targets": [{
        "expr": "sum(increase(auth_ssh_success_total[24h]))",
        "legendFormat": "Success"
      }]
    },
    {
      "title": "Sudo Commands (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      },
      "targets": [{
        "expr": "sum(increase(auth_sudo_total[24h]))",
        "legendFormat": "Sudo"
      }]
    },
    {
      "title": "Currently Tracked IPs",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus" },
      "targets": [{
        "expr": "count(auth_ssh_failed_by_ip > 0)",
        "legendFormat": "IPs"
      }]
    },
    {
      "title": "Failed Logins Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "cps"
        }
      },
      "targets": [{
        "expr": "sum(rate(auth_ssh_failed_total[5m]))",
        "legendFormat": "failed/s"
      }]
    },
    {
      "title": "Successful Logins Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus" },
      "targets": [{
        "expr": "sum(rate(auth_ssh_success_total[5m]))",
        "legendFormat": "success/s"
      }]
    },
    {
      "title": "Top Offending IPs",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      },
      "targets": [{
        "expr": "topk(10, auth_ssh_failed_by_ip)",
        "legendFormat": "{{ip}}"
      }]
    },
    {
      "title": "Auth Events by User",
      "type": "table",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 12 },
      "datasource": { "type": "prometheus" },
      "targets": [{
        "expr": "sum by (user) (rate(auth_ssh_failed_total[24h]))",
        "legendFormat": "failed {{user}}"
      },{
        "expr": "sum by (user) (rate(auth_ssh_success_total[24h]))",
        "legendFormat": "success {{user}}"
      }]
    },
    {
      "title": "Sudo Activity (24h)",
      "type": "table",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 12 },
      "datasource": { "type": "prometheus" },
      "targets": [{
        "expr": "topk(10, sum by (user, command) (increase(auth_sudo_total[24h])))",
        "legendFormat": "{{user}}: {{command}}"
      }]
    }
  ]
}
